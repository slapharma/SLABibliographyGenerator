# Copy this file to .env.local for local development
# In Netlify: set these in Site Settings → Environment Variables

# Required: auto-injected by Netlify DB (Neon Postgres)
# For local dev: copy from Netlify dashboard → Site → Integrations → Databases
DATABASE_URL=postgresql://user:password@host/dbname

# Optional: raises PubMed API rate limit from 3/sec to 10/sec
# Get free at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# Optional: enables Lens.org patent + literature search
# Get free at: https://www.lens.org/lens/user/subscriptions
LENS_API_KEY=

# Optional: enables Google Scholar via SerpAPI
# Get free tier at: https://serpapi.com/
# If absent, Google Scholar chip is hidden from search form
SERPAPI_KEY=

# Optional: raises Semantic Scholar rate limit
# Get free at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_KEY=
